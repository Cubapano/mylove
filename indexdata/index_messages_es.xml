  <data name="es_project_description"><![CDATA[<font face="verdana, sans-serif">Lo mas valioso de la vida no es lo que tenemos, sino a quienes tenemos.</font>]]></data>



  <data name="es_spotpoint10360_description"><![CDATA[<p><span style="line-height: 107%; font-family: Verdana, sans-serif;"><font size="2">Haberte encontrado mientras no buscaba nada, fue lo más lindo que me pudo pasar.</font></span><o:p></o:p></p>]]></data>



  <data name="es_spotpoint10578_description"><![CDATA[<p><span style="line-height: 107%; font-family: Verdana, sans-serif;"><font size="2">Y pase lo que pase, t</font></span><span style="font-family: Verdana, sans-serif; font-size: small;">ú</span><span style="line-height: 107%; font-family: Verdana, sans-serif;"><font size="2">&nbsp;siempre serás mi más bonita casualidad; ese recuerdo que nunca quiero borrar; quien me enseñó a reír justo cuando más dolía la vida; el arte que estremeció mi alma; mi lugar más seguro en el mundo, y la única persona que se atrevió a abrazar mis imperfecciones y mi oscuridad sin miedo a nada.</font></span><o:p></o:p></p>]]></data>



  <data name="es_spotpoint10382_description"><![CDATA[<p><span style="font-family: Verdana, sans-serif;"><font size="2">Tú nunca serás mi demasiado tarde, eres mi hora exacta y mi felicidad a tiempo.</font></span><o:p></o:p></p>]]></data>



